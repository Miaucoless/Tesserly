"build": {
  "appId": "com.tesserly.app",
  "productName": "Tesserly",

  "publish": [
    {
      "provider": "github",
      "owner": "Miaucoless",
      "repo": "Tesserly"
    }
  ],

  "files": [
    "src/**/*",
    "assets/**/*",
    "!**/*.map"
  ],

  "directories": {
    "output": "dist"
  },

  "mac": {
    "category": "public.app-category.education",
    "target": [
      "dmg",
      "zip"
    ],
    "icon": "icons/icon.icns"
  },

  "dmg": {
    "background": "build/dmg-background.png",
    "window": {
      "width": 600,
      "height": 400
    },
    "contents": [
      { "x": 130, "y": 200, "type": "file" },
      { "x": 450, "y": 200, "type": "link", "path": "/Applications" }
    ]
  },

  "win": {
    "target": ["nsis"],
    "icon": "icons/icon.ico"
  },

  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "installerIcon": "icons/icon.ico",
    "uninstallerIcon": "icons/icon.ico",
    "installerHeaderIcon": "icons/icon.ico",
    "deleteAppDataOnUninstall": true
  }
}